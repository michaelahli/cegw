      "properties": {
        "symbol": {
          "type": "string",
          "example": "BTC/USDT"
        },
        "bids": {
          "type": "array",
          "description": "List of buy orders sorted by price descending. Each entry is [price, volume].",
          "items": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            }
          },
          "example": [
            [68000.5, 1.2],
            [67999.0, 0.5]
          ]
        },
        "asks": {
          "type": "array",
          "description": "List of sell orders sorted by price ascending. Each entry is [price, volume].",
          "items": {
            "type": "array",
            "items": {
              "type": "number",
              "format": "double"
            }
          },
          "example": [
            [68001.0, 0.8],
            [68002.5, 1.0]
          ]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "example": "2026-06-08T12:55:50Z"
        }
      }
    },
    "WebSocketErrorMessage": {
      "type": "object",
      "description": "JSON error message sent before the WebSocket connection is closed when streaming cannot continue after upgrade.",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "string",
          "example": "failed to watch ticker"
        }
      }
    }
  }
}
