        "EXCHANGE_BINANCE",
        "EXCHANGE_COINBASE",
        "EXCHANGE_CEXIO",
        "EXCHANGE_INDODAX",
        "EXCHANGE_OKX",
        "EXCHANGE_KUCOIN",
        "EXCHANGE_CRYPTOCOM",
        "EXCHANGE_BYBIT",
        "EXCHANGE_BITGET",
        "EXCHANGE_COINEX",
        "EXCHANGE_HASHKEY"
      ],
      "default": "EXCHANGE_UNSPECIFIED"
    },
    "v1GetCurrentPriceResponse": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string"
        },
        "price": {
          "type": "number",
