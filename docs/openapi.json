{
  "swagger": "2.0",
  "info": {
    "title": "CEGW API",
    "version": "1.0.0",
    "description": "Crypto Exchange Gateway - Unified API for cryptocurrency exchange integration"
  },
  "tags": [
    {
      "name": "Market Data",
      "description": "Market data operations"
    },
    {
      "name": "Trading",
      "description": "Trading operations"
    },
    {
      "name": "Monitoring",
      "description": "Monitoring and alerts"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/market/list": {
      "get": {
        "summary": "List Markets",
        "description": "Get all available trading pairs for an exchange.",
        "operationId": "MarketDataService_ListMarkets",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1ListMarketsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "exchange",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "EXCHANGE_UNSPECIFIED",
              "EXCHANGE_TOKOCRYPTO",
              "EXCHANGE_BINANCE",
              "EXCHANGE_COINBASE",
              "EXCHANGE_CEXIO",
              "EXCHANGE_INDODAX",
              "EXCHANGE_OKX",
              "EXCHANGE_KUCOIN",
              "EXCHANGE_CRYPTOCOM",
              "EXCHANGE_BYBIT",
              "EXCHANGE_BITGET",
              "EXCHANGE_COINEX",
              "EXCHANGE_HASHKEY"
            ],
            "default": "EXCHANGE_UNSPECIFIED"
          }
        ],
        "tags": [
          "Market Data"
        ]
      }
    },
    "/v1/market/price/{exchange}/{symbol}": {
      "get": {
        "summary": "Get Current Price",
        "description": "Retrieves the latest ticker price for a trading pair.",
        "operationId": "MarketDataService_GetCurrentPrice",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetCurrentPriceResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "exchange",
            "in": "path",
            "required": true,
            "type": "string",
            "enum": [
              "EXCHANGE_UNSPECIFIED",
              "EXCHANGE_TOKOCRYPTO",
              "EXCHANGE_BINANCE",
              "EXCHANGE_COINBASE",
              "EXCHANGE_CEXIO",
              "EXCHANGE_INDODAX",
              "EXCHANGE_OKX",
              "EXCHANGE_KUCOIN",
              "EXCHANGE_CRYPTOCOM",
              "EXCHANGE_BYBIT",
              "EXCHANGE_BITGET",
              "EXCHANGE_COINEX",
              "EXCHANGE_HASHKEY"
            ]
          },
          {
            "name": "symbol",
            "in": "path",
            "required": true,
            "type": "string",
            "pattern": ".+"
          }
        ],
        "tags": [
          "Market Data"
        ]
      }
    },
    "/v1/market/quotes": {
      "post": {
        "summary": "Get Historical Quotes",
        "description": "Retrieves historical OHLCV (Open, High, Low, Close, Volume) data for a trading pair from the specified exchange.",
        "operationId": "MarketDataService_GetQuotes",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetQuotesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1GetQuotesRequest"
            }
          }
        ],
        "tags": [
          "Market Data"
        ]
      }
    },
    "/v1/market/search": {
      "get": {
        "summary": "Search Tickers",
        "description": "Search available trading pairs by query string.",
        "operationId": "MarketDataService_SearchTicker",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1SearchTickerResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "exchange",
            "in": "query",
            "required": false,
            "type": "string",
            "enum": [
              "EXCHANGE_UNSPECIFIED",
              "EXCHANGE_TOKOCRYPTO",
              "EXCHANGE_BINANCE",
              "EXCHANGE_COINBASE",
              "EXCHANGE_CEXIO",
              "EXCHANGE_INDODAX",
              "EXCHANGE_OKX",
              "EXCHANGE_KUCOIN",
              "EXCHANGE_CRYPTOCOM",
              "EXCHANGE_BYBIT",
              "EXCHANGE_BITGET",
              "EXCHANGE_COINEX",
              "EXCHANGE_HASHKEY"
            ],
            "default": "EXCHANGE_UNSPECIFIED"
          },
          {
            "name": "query",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "Market Data"
        ]
      }
    },
    "/v1/monitoring/alerts": {
      "post": {
        "summary": "Check Price Alerts",
        "description": "Evaluate price alert conditions against current market prices.",
        "operationId": "MonitoringService_CheckPriceAlerts",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CheckPriceAlertsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CheckPriceAlertsRequest"
            }
          }
        ],
        "tags": [
          "Monitoring"
        ]
      }
    },
    "/v1/trading/credentials/test": {
      "post": {
        "summary": "Test Credentials",
        "description": "Validate API credentials for an exchange.",
        "operationId": "TradingService_TestCredentials",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1TestCredentialsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1TestCredentialsRequest"
            }
          }
        ],
        "tags": [
          "Trading"
        ]
      }
    },
    "/v1/trading/order": {
      "post": {
        "summary": "Create Market Order",
        "description": "Place a market buy or sell order on the specified exchange.",
        "operationId": "TradingService_CreateMarketOrder",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CreateMarketOrderResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateMarketOrderRequest"
            }
          }
        ],
        "tags": [
          "Trading"
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1Exchange": {
