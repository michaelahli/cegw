FROM golang:1.25-alpine AS builder

WORKDIR /build

RUN apk add --no-cache git

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go mod tidy

RUN CGO_ENABLED=0 GOOS=linux go build -o cegw ./cmd/cegw

FROM alpine:latest

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /build/cegw .
COPY --from=builder /build/docs ./docs
COPY --from=builder /build/pkg/client/example ./pkg/client/example

RUN mkdir -p /tmp

EXPOSE 50051 8080

ENTRYPOINT ["./cegw"]
